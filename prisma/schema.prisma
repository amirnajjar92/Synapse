generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model AIConversation {
  id          String             @id @default(cuid())
  userId      String
  sessionId   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AIMessage[]

  @@index([userId, createdAt])
}

model AIMessage {
  id              String           @id @default(cuid())
  conversationId  String
  role            String
  content         String           @db.Text
  intent          String?
  confidence      String?
  contextPage     String?
  metadata        Json?
  createdAt       DateTime         @default(now())

  conversation    AIConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Activity {
  id               String   @id @default(cuid())
  userId           String
  stravaId         String   @unique
  type             String
  name             String
  startDate        DateTime
  distance         Float
  movingTime       Int
  elapsedTime      Int
  averageSpeed     Float?
  maxSpeed         Float?
  averageHeartRate Int?
  maxHeartRate     Int?
  calories         Float?
  externalId       String?
  polyline         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyEntry {
  id          String        @id @default(cuid())
  userId      String
  planId      String
  date        DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  aiAnalysis  String?
  todos       String[]
  plan        Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media       DailyMedia[]
  metrics     DailyMetric[]

  @@unique([userId, planId, date])
}

model DailyMedia {
  id           String     @id @default(cuid())
  dailyEntryId String
  type         String
  url          String
  fileName     String?
  createdAt    DateTime   @default(now())
  dailyEntry   DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)
}

model DailyMetric {
  id           String     @id @default(cuid())
  dailyEntryId String
  type         String
  value        Float
  unit         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  dailyEntry   DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)
}

model Plan {
  id             String       @id @default(cuid())
  userId         String
  title          String
  prompt         String
  icon           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  endDate        DateTime?
  startDate      DateTime?
  status         PlanStatus   @default(NOT_STARTED)
  goalWeight     Float?
  goalWeightUnit String?
  dailyEntries   DailyEntry[]
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tables         PlanTable[]
  userPrompts    UserPrompt[]
}

model PlanRow {
  id        String    @id @default(cuid())
  tableId   String
  columns   String[]
  createdAt DateTime  @default(now())
  planTable PlanTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model PlanTable {
  id        String    @id @default(cuid())
  planId    String
  title     String
  createdAt DateTime  @default(now())
  rows      PlanRow[]
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  role           UserRole         @default(USER)
  conversations  AIConversation[]
  accounts       Account[]
  activities     Activity[]
  dailyEntries   DailyEntry[]
  plans          Plan[]
  sessions       Session[]
  userPrompts    UserPrompt[]
  waterLogs      WaterLog[]
}

model UserPrompt {
  id        String   @id @default(cuid())
  userId    String
  planId    String?
  prompt    String
  createdAt DateTime @default(now())
  plan      Plan?    @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  cups      Int      @default(0)
  goalCups  Int      @default(12)
  createdAt DateTime @default(now())
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum PlanStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum UserRole {
  USER
  ADMIN
}
